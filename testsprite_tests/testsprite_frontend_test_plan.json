  {
    "id": "TC001",
    "title": "View diary list and open a diary entry from the list",
    "description": "Verifies an authenticated user can view the played games list and open a specific diary entry from it.",
    "category": "Game Diary List",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/diary\""
      },
      {
        "type": "assertion",
        "description": "Verify element \"Played games list\" is visible"
